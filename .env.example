# Mercado Livre App Credentials
ML_CLIENT_ID=your_client_id
ML_CLIENT_SECRET=your_client_secret
ML_REDIRECT_URI=http://localhost:3001/api/auth/callback

# Server
PORT=3001
NODE_ENV=development

# Database (required for production, optional for development)
# Railway provides this automatically when you add a PostgreSQL database
DATABASE_URL=postgresql://user:password@localhost:5432/meliprint

# Redis (optional - faster than PostgreSQL for sessions)
# Railway provides this automatically when you add a Redis database
# REDIS_URL=redis://default:password@localhost:6379

# Mercado Pago (for subscriptions)
# Get your credentials at: https://www.mercadopago.com.br/developers/panel/app
MP_ACCESS_TOKEN=your_mercado_pago_access_token

# Mercado Pago webhook secret (App > Webhooks > "Chave secreta" in the Developer Panel)
# Used to validate that webhook requests really come from Mercado Pago.
# Also remember to configure the webhook URL there (topic: "Assinaturas"):
#   https://your-domain.com/api/subscription/webhook
MP_WEBHOOK_SECRET=your_mercado_pago_webhook_secret

# Sentry (optional - error monitoring)
# Get your DSN at: https://sentry.io
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Session
SESSION_SECRET=your_session_secret_here

# Admin panel (used to protect /admin and /api/admin/*)
ADMIN_SECRET=choose_a_strong_random_secret

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
